{
  "rules": {
    "$note": {
      ".read": true,
      ".write": true,
      ".validate": "newData.hasChildren(['text']) || newData.hasChildren(['secret', 'encryptedText', 'salt', 'iv'])",
      "text": { ".validate": "newData.isString()" },
      "secret": { ".validate": "newData.val() === true" },
      "encryptedText": { ".validate": "newData.isString()" },
      "salt": { ".validate": "newData.isString()" },
      "iv": { ".validate": "newData.isString()" },
      "$other": { ".validate": false }
    }
  }
}
